  m_text: "OBJETIVO:\r\nSobrevive o m\xE1ximo de tempo poss\xEDvel e bate o teu recorde
    de dist\xE2ncia! \r\n\r\nCONTROLOS:\r\n\u2022 Mover: Teclas [ A ] e [ D ] (ou
    Setas Laterais)\r\n\u2022 Saltar: Tecla [ ESPA\xC7O ] ou [ W ]\r\n\r\nREGRAS:\n\u2022Apanha
    as moedas amarelas para ficares rico.\n\u2022Estrela M\xE1gica: Ativa o Turbo!
    Ficas 2x mais r\xE1pida durante 5 segundos. Cuidado: a velocidade aumenta, mas
    os reflexos t\xEAm de ser maiores!\r\n\u2022Evita os obst\xE1culos a todo o custo.
    Bater significa GAME OVER imediato!\r\n\r\nBoa sorte, corredor!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
